{
  "name": "mentara",
  "version": "0.1.0",
  "description": "Mentara: a dynamic bonding curve launch protocol and SDK for Sui. The brain that powers token launchpads.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./math": { "types": "./dist/math.d.ts", "import": "./dist/math.js" },
    "./read": { "types": "./dist/read.d.ts", "import": "./dist/read.js" },
    "./tx": { "types": "./dist/tx.d.ts", "import": "./dist/tx.js" },
    "./coin": { "types": "./dist/coin.d.ts", "import": "./dist/coin.js" },
    "./client": { "types": "./dist/client.d.ts", "import": "./dist/client.js" },
    "./types": { "types": "./dist/types.d.ts", "import": "./dist/types.js" }
  },
  "files": ["dist", "src", "move", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": ["sui", "bonding-curve", "launchpad", "defi", "meteora", "token", "amm"],
  "author": "MS Mind Labs",
  "license": "MIT",
  "homepage": "https://mentara.dev",
  "dependencies": {
    "@mysten/move-bytecode-template": "^0.4.0"
  },
  "peerDependencies": {
    "@mysten/sui": "^1.30.0"
  },
  "devDependencies": {
    "@mysten/sui": "^1.30.0",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
